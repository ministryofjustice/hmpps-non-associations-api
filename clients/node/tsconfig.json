 {
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@tsconfig/node24/tsconfig.json",
  "compileOnSave": true,
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "strict": true,
    "noImplicitAny": true,
    "experimentalDecorators": true,
    "isolatedModules": true,
    "typeRoots": [
      "./node_modules/@types",
      "./node_modules",
    ],
    "types": [
      "node",
      "jest",
    ]
  },
  "exclude": [
    "dist",
    "node_modules",
  ],
  "include": [
    "src/**/*.ts",
    "test/**/*.ts"
  ],
}
